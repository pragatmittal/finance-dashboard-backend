# MongoDB connection string used by the API and the canonical seed script
MONGO_URI=mongodb://127.0.0.1:27017/finance_dashboard

# Secret used to sign and verify JWTs
JWT_SECRET=replace-with-a-long-random-secret

# Optional JWT lifetime used when issuing tokens
JWT_EXPIRES_IN=7d

# Server configuration
PORT=3000
NODE_ENV=development

# MongoDB connection string used by npm test
MONGO_URI_TEST=mongodb://127.0.0.1:27017/finance_dashboard_test
